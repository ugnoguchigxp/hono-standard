{
  "name": "@repo/design-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*",
    "./lib/*": "./src/lib/*",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm pencil:variants && vite build",
    "storybook": "pnpm pencil:variants && storybook dev -p 6006",
    "storybook:build": "pnpm pencil:variants && storybook build",
    "pencil:variants": "node ./pencil/scripts/sync-variants.mjs",
    "generate-tokens": "tsx ./scripts/generate-tokens.mts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "lint": "biome check ."
  },
  "dependencies": {
    "@base-ui/react": "latest",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "storybook": "^10.3.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-dom": "^0.1.1"
  }
}
