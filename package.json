{
  "name": "hono-standard",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "prepare": "husky",
    "build": "pnpm build:frontend && pnpm build:backend",
    "build:frontend": "vite build",
    "build:backend": "esbuild api/index.ts --bundle --packages=external --platform=node --target=node20 --format=esm --outfile=dist-api/index.js",
    "start": "cross-env NODE_ENV=production node dist-api/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check api src shared tests README.md .env.example package.json tsconfig.json vite.config.ts vitest.config.ts playwright.config.ts",
    "lint:all": "biome check .",
    "pencil:variants": "pnpm -C designSystem pencil:variants",
    "design-system:variants": "pnpm -C designSystem pencil:variants",
    "generate-tokens": "pnpm -C designSystem generate-tokens",
    "design-system:storybook": "pnpm -C designSystem storybook",
    "design-system:storybook:build": "pnpm -C designSystem storybook:build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx drizzle/seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:regression": "playwright test --grep @regression"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.12",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.4",
    "@hono/zod-validator": "^0.7.6",
    "@repo/design-system": "workspace:*",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-table": "^8.21.3",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.2",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@hono/vite-dev-server": "^0.25.1",
    "@playwright/test": "^1.59.1",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.5",
    "husky": "^9.1.7",
    "msw": "^2.12.14",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
