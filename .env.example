# Application
NODE_ENV=development
PORT=3000
# Required when AUTH_MODE is "oauth" or "both"
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
COOKIE_SAME_SITE=lax # "none" requires secure cookies (HTTPS APP_URL or production)
TRUST_PROXY=false
VITE_ENABLE_MSW=false
LOG_LEVEL=info
AUTH_MODE=both

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hono_standard

# Security (JWT)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth Providers
# If AUTH_MODE is "oauth", configure at least one provider pair.
# If AUTH_MODE is "both", configure when OAuth login is enabled.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
