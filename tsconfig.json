{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@api/*": ["./api/*"],
      "@repo/design-system": ["./designSystem/src"],
      "@repo/design-system/*": ["./designSystem/src/*"],
      "@repo/design-system/pencil": ["./designSystem/pencil"]
    },
    "types": ["node", "vite/client"]
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules", "dist", "drizzle"]
}
